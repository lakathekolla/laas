{
    "name": "laas",
    "displayName": "LaaS",
    "description": "Lazy as a Service for developers — launch, stop, restart, and monitor your local dev stack from one clean control panel.",
    "version": "0.1.3",
    "publisher": "lakruwanx",
    "license": "MIT",
    "icon": "media/icon.png",
    "engines": {
        "vscode": "^1.85.0"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/lakruwanx/laas"
    },
    "homepage": "https://github.com/lakruwanx/laas#readme",
    "bugs": {
        "url": "https://github.com/lakruwanx/laas/issues"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "main": "./dist/extension.js",
    "contributes": {
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "laas",
                    "title": "LaaS",
                    "icon": "media/icon.svg"
                }
            ]
        },
        "views": {
            "laas": [
                {
                    "id": "laas.panel",
                    "name": "Dev Servers",
                    "type": "webview"
                }
            ]
        },
        "commands": [
            {
                "command": "laas.startAll",
                "title": "LaaS: Start All"
            },
            {
                "command": "laas.stopAll",
                "title": "LaaS: Stop All"
            },
            {
                "command": "laas.restartAll",
                "title": "LaaS: Restart All"
            },
            {
                "command": "laas.showOutput",
                "title": "LaaS: Show Output"
            }
        ],
        "configuration": {
            "title": "LaaS",
            "properties": {
                "laas.laravelCommand": {
                    "type": "string",
                    "default": "php artisan serve",
                    "description": "Command used to start the Laravel development server."
                },
                "laas.viteCommand": {
                    "type": "string",
                    "default": "npm run dev",
                    "description": "Command used to start the Vite development server."
                },
                "laas.ngrokCommand": {
                    "type": "string",
                    "default": "ngrok http 8000",
                    "description": "Command used to start ngrok."
                },
                "laas.autoShowOnStart": {
                    "type": "boolean",
                    "default": false,
                    "description": "Automatically focus terminals when starting services."
                },
                "laas.statusBarAlignment": {
                    "type": "string",
                    "enum": [
                        "left",
                        "right"
                    ],
                    "default": "left",
                    "description": "Choose where LaaS controls appear in the status bar."
                }
            }
        }
    },
    "scripts": {
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./"
    },
    "devDependencies": {
        "@types/node": "^20.11.30",
        "@types/vscode": "^1.85.0",
        "typescript": "^5.4.5"
    }
}